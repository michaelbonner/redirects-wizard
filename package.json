{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "start": "bun ./build/index.js",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:copy-production-to-preview": "bun scripts/copy-production-db-to-preview.ts",
        "db:migrate:laravel": "bun scripts/migrate-laravel-mysql-to-postgres.ts",
        "lint": "prettier --check src scripts components.json svelte.config.js vite.config.ts tsconfig.json drizzle.config.ts package.json README.md docker-compose.yml nixpacks.toml --ignore-unknown"
    },
    "dependencies": {
        "@better-auth/drizzle-adapter": "^1.4.0",
        "@tailwindcss/vite": "^4.1.17",
        "better-auth": "^1.4.7",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.0",
        "kysely": "0.28.8",
        "lucide-svelte": "^0.556.0",
        "mysql2": "^3.22.5",
        "postgres": "^3.4.7",
        "svelte": "^5.43.14",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@internationalized/date": "^3.12.0",
        "@lucide/svelte": "^1.17.0",
        "@sveltejs/kit": "^2.49.1",
        "@sveltejs/vite-plugin-svelte": "^6.2.1",
        "bits-ui": "^2.16.3",
        "drizzle-kit": "^0.31.8",
        "prettier": "^3.7.4",
        "prettier-plugin-svelte": "^3.4.0",
        "prettier-plugin-tailwindcss": "^0.7.1",
        "shadcn-svelte": "^1.3.0",
        "svelte-adapter-bun": "^1.0.1",
        "svelte-check": "^4.3.4",
        "tailwind-variants": "^3.2.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vite": "^7.2.7"
    },
    "engines": {
        "node": "22.22.0"
    }
}
