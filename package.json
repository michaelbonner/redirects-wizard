{
    "private": true,
    "type": "module",
    "scripts": {
        "prepare": "lefthook install",
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "start": "bun db:migrate && bun ./build/index.js",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:copy-production-to-preview": "bun scripts/copy-production-db-to-preview.ts",
        "db:copy-production-to-local": "bun scripts/copy-production-db-to-local.ts",
        "format": "vp fmt --write",
        "lint": "vp fmt --check && vp lint"
    },
    "dependencies": {
        "@better-auth/drizzle-adapter": "^1.6.23",
        "@tailwindcss/vite": "^4.3.2",
        "better-auth": "^1.6.23",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.2",
        "lucide-svelte": "^1.0.1",
        "playwright": "^1.61.1",
        "postgres": "^3.4.9",
        "svelte": "^5.56.4",
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@internationalized/date": "^3.12.2",
        "@lucide/svelte": "^1.23.0",
        "@sveltejs/kit": "^2.69.1",
        "@sveltejs/vite-plugin-svelte": "^7.2.0",
        "@types/node": "^26.1.0",
        "bits-ui": "^2.18.1",
        "drizzle-kit": "^0.31.10",
        "lefthook": "^2.1.9",
        "shadcn-svelte": "^1.3.0",
        "svelte-adapter-bun": "^1.0.1",
        "svelte-check": "^4.7.2",
        "tailwind-variants": "^3.2.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "vite": "^8.1.3"
    },
    "engines": {
        "node": "22.22.0"
    }
}
